{
  "name": "favorite-eats",
  "productName": "Favorite Eats Editor",
  "version": "1.0.0",
  "main": "electronMain.js",
  "scripts": {
    "start": "electron .",
    "build:web": "node scripts/buildWeb.js",
    "build:electron": "electron-builder",
    "dist": "npm run build:electron",
    "test:ingredient-display": "node tests/runIngredientDisplayTests.js",
    "test:ingredient-parser": "node tests/runIngredientPasteParserTests.js",
    "test:recipe-tags-keyboard": "node tests/runRecipeTagsKeyboardTests.js",
    "test:shopping-identity-migration": "node tests/runShoppingIdentityMigrationTests.js",
    "test:typeahead-keyboard": "node tests/runTypeaheadKeyboardTests.js",
    "test:unit-size-state": "node tests/runUnitSizeStateTests.js",
    "test:web-build": "node tests/runWebBuildTests.js",
    "test:normalize-temperature": "node tests/runNormalizeTemperatureTests.js",
    "audit:name-pairs": "node scripts/audit-name-pairs.js"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.0.12",
    "sql.js": "^1.12.0"
  },
  "build": {
    "appId": "com.spoonfloor.favoriteeats",
    "files": [
      "**/*",
      "!recipe-lan-server/**",
      "!**/.venv/**"
    ],
    "mac": {
      "icon": "assets/app-icon.icns"
    },
    "win": {
      "icon": "assets/app-icon.ico"
    }
  }
}
