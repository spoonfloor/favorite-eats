{
  "_comment": "Parity fixtures for loadRecipeDetail. Each fixture has an `input` describing the rows that exist in the data source, a `recipeId` to query, and an `expected` object (or null) describing the canonical output. Both adapters must reproduce `expected` exactly.",

  "schema": {
    "input": {
      "recipes": "Array of recipe rows. Fields: ID, title, servings_default, servings_min, servings_max.",
      "tags": "Array of tag rows. Fields: id, name, is_hidden, sort_order.",
      "recipe_tag_map": "Recipe-to-tag links. Fields: id, recipe_id, tag_id, sort_order.",
      "recipe_steps": "Step rows. Fields: ID, recipe_id, step_number, instructions, type.",
      "ingredients": "Ingredient catalog rows. Fields: ID, name, variant, size, parenthetical_note, lemma, plural_by_default, is_mass_noun, plural_override, is_deprecated.",
      "ingredient_variants": "Ingredient-variant rows used for home_location lookup. Fields: id, ingredient_id, variant, home_location, is_deprecated.",
      "recipe_ingredient_map": "Per-recipe ingredient rows. Fields: ID, recipe_id, ingredient_id, section_id, sort_order, quantity, quantity_min, quantity_max, quantity_is_approx, unit, variant, size, prep_notes, is_optional, parenthetical_note, is_recipe, linked_recipe_id, recipe_text, is_alt, display_name.",
      "recipe_ingredient_headings": "Sub-section heading rows. Fields: ID, recipe_id, section_id, sort_order, text. May be omitted entirely to simulate legacy DB without the table."
    },
    "recipeId": "Numeric ID to pass to loadRecipeDetail.",
    "expected": "Recipe object per js/data/contracts/loadRecipeDetail.md, or null."
  },

  "fixtures": [
    {
